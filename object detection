   "outputs": [],
   "source": [
    "print(\"[4/5] Training (20 epochs)...\")\n",
    "EPOCHS          = 20\n",
    "STEPS_PER_EPOCH = 60000 // BATCH_SIZE  # full MNIST training set = 937 steps\n",
